# Environment Variables untuk Website Desa Karangtalun
# 
# File ini adalah template (COMMIT ke repo sebagai dokumentasi).
# Copy file ini jadi `.env` dan isi dengan value asli (JANGAN commit .env).
#
# Di Cloudflare Pages: set variable ini di dashboard project → Settings → Environment Variables

# ─── Site Configuration ──────────────────────────────────────────────────────
# Base URL website (untuk absolute URL di OpenGraph meta tags)
# Development: http://localhost:5173
# Production: https://karangtalun.id (atau domain yang Anda gunakan)
VITE_SITE_URL=

# ─── External Data Sources (untuk `npm run fetch-data`) ──────────────────────
# API Key BPS (Badan Pusat Statistik)
BPS_API_KEY=

# Google Sheets CSV Export URLs
GOOGLE_SHEET_CSV_URL_UMKM_DESA=
GOOGLE_SHEET_CSV_URL_WISATA_KULINER=
GOOGLE_SHEET_CSV_URL_GALERI_DESA=
GOOGLE_SHEET_CSV_URL_DOKUMENTASI_DESA=
GOOGLE_SHEET_CSV_URL_FASILITAS=
